# Copy this file to .env and fill in the values
# Generate VAPID keys with: python generate_keys.py

VAPID_PRIVATE_KEY=your_base64url_private_key_here
VAPID_PUBLIC_KEY=your_base64url_public_key_here
VAPID_CLAIMS_EMAIL=admin@yourdomain.com

# Paths (defaults work for Docker)
DB_PATH=/data/app.db
DATA_DIR=/data
FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf

# Optional: browser to use for YouTube cookies (avoids bot detection)
# Values: edge, chrome, firefox, brave, opera  — leave empty on Linux servers
# YTDLP_BROWSER=edge
